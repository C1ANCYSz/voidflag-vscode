{
  "name": "voidflag-vf",
  "displayName": "VoidFlag (.vf)",
  "description": "Syntax highlighting and diagnostics for VoidFlag schema files",
  "version": "0.0.3",
  "publisher": "VoidFlag",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/C1ANCYSz/voidflag-vscode"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "jsonValidation": [
      {
        "fileMatch": [
          "voidflag.json",
          "voidflag.config.json",
          "vf.json",
          "vf.config.json"
        ],
        "url": "./schema.json"
      }
    ],
    "languages": [
      {
        "id": "voidflag",
        "aliases": [
          "VoidFlag",
          "vf"
        ],
        "extensions": [
          ".vf"
        ],
        "configuration": "./languageConfig.json",
        "icon": {
          "light": "icons/vf-light.svg",
          "dark": "icons/vf.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "voidflag",
        "scopeName": "source.vf",
        "path": "./syntaxes/voidflag.tmLanguage.json"
      }
    ],
    "iconThemes": [
      {
        "id": "voidflag-icons",
        "label": "VoidFlag Icons",
        "path": "./icons/icon-theme.json"
      }
    ]
  },
  "icon": "icons/ext-icon.png",
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "package": "node esbuild.mjs && vsce package --no-dependencies"
  },
  "dependencies": {},
  "bundledDependencies": [],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.82.0",
    "@voidflag/parser": "workspace:*",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.0.0",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  }
}
